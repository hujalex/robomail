{
  "name": "robomail-sdk",
  "version": "0.0.1",
  "description": "TypeScript SDK for the Robomail API — give AI agents their own email inboxes",
  "keywords": ["robomail", "email", "ai", "agent", "sdk", "inbox"],
  "license": "MIT",
  "main": "./index.js",
  "module": "./index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./index.d.ts",
        "default": "./index.js"
      }
    }
  },
  "scripts": {
    "build": "tsc"
  },
  "devDependencies": {
    "typescript": "^5.0.0"
  },
  "files": [
    "**/*.js",
    "**/*.js.map",
    "**/*.d.ts",
    "**/*.d.ts.map",
    "!node_modules"
  ],
  "engines": {
    "node": ">=18"
  }
}
